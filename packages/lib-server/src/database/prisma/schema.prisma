// Notification System Models
model Notification {
  id          String   @id @default(cuid())
  userId      String   // 接收通知的用户ID
  type        NotificationType
  title       String   // 通知标题
  content     String   // 通知内容
  metadata    Json?    // 扩展数据（如关联的作品ID、组织ID等）
  read        Boolean  @default(false)
  readAt      DateTime?
  actionUrl   String?  // 可选的操作链接
  priority    NotificationPriority @default(NORMAL)
  
  // 关联数据
  relatedUserId String? // 触发通知的用户ID
  relatedUser   User?   @relation("RelatedNotifications", fields: [relatedUserId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relations
  emailNotifications EmailNotificationQueue[]

  @@index([userId, createdAt])
  @@index([userId, read])
  @@index([userId, priority, createdAt]) // 优先级通知查询优化
  @@map("notification")
}

