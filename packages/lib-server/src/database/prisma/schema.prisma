  @@map("notification_preference")
}

model EmailNotificationQueue {
  id            String   @id @default(cuid())
  userId        String
  notificationId String?
  emailType     String   // 邮件模板类型
  emailData     Json     // 邮件数据
  priority      NotificationPriority @default(NORMAL)
