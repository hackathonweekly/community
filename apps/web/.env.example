# Build-time environment variables for CNB pipeline
# These are public values that can be safely committed to git

# ============================================
# Site / Application URLs
# ============================================

# Site URL - used for static generation, sitemap, SEO, etc.
NEXT_PUBLIC_SITE_URL=

# Application URL - used for email links, redirects, etc. Falls back to NEXT_PUBLIC_SITE_URL.
NEXT_PUBLIC_APP_URL=

# Public API URL (optional, defaults to NEXT_PUBLIC_SITE_URL if not set)
NEXT_PUBLIC_API_URL=

# ============================================
# Database
# ============================================

# PostgreSQL connection string for Prisma
DATABASE_URL=

# ============================================
# Authentication (Better Auth)
# ============================================

# Auth secret - generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Auth URL - must match your app's base URL (e.g., http://localhost:3000 for dev)
BETTER_AUTH_URL=

# Trusted Origins (comma-separated list of domains allowed for auth)
TRUSTED_ORIGINS=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WeChat Website Login
WECHAT_WEBSITE_APP_ID=
WECHAT_WEBSITE_APP_SECRET=

# WeChat Service Account
WECHAT_SERVICE_ACCOUNT_APP_ID=
WECHAT_SERVICE_ACCOUNT_APP_SECRET=

# ============================================
# Storage (Tencent Cloud COS / S3-compatible)
# ============================================

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=

# Public S3 bucket configuration (Tencent Cloud COS)
# Bucket has public read, private write permissions
NEXT_PUBLIC_BUCKET_NAME=
NEXT_PUBLIC_S3_ENDPOINT=

# ============================================
# Email
# ============================================

PLUNK_API_KEY=

# Enable real email sending in development
ENABLE_EMAIL_IN_DEV=true

# ============================================
# Tencent Cloud (SMS, Content Moderation, etc.)
# ============================================

TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_CLOUD_REGION=ap-shanghai

# SMS configuration
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_EVENT_APPROVED_TEMPLATE_ID=
TENCENT_SMS_EVENT_REJECTED_TEMPLATE_ID=

# Content Moderation biztype
TENCENT_CMS_BIZTYPE=content_input

# ============================================
# AI / OpenAI-compatible API
# ============================================

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ============================================
# Analytics
# ============================================

# Priority: Umami > Google Analytics > Baidu Analytics
# Umami (privacy-friendly, open-source)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# Google Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Baidu Analytics (optional)
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=

# ============================================
# Telemetry & Debug
# ============================================

# Set to 1 to disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# Suppress punycode deprecation warning from Prisma
NODE_OPTIONS=--no-deprecation

# Disable verbose HTTP request logging in development
DISABLE_HTTP_LOGGING=false
